<recoveryPassword:RecoveryPasswordWindow
    xmlns="https://spacestation14.io"
    xmlns:recoveryPassword="clr-namespace:Content.Goobstation.Client.RecoveryPassword"
    Title="{Loc 'recovery-password-window-title'}"
    MinSize="440 0">
    <BoxContainer Orientation="Vertical" Margin="8" SeparationOverride="6">
        <RichTextLabel Name="InfoLabel" Access="Public" />
        <BoxContainer Orientation="Vertical" SeparationOverride="2">
            <Label Text="{Loc 'recovery-password-field-label'}" StyleClasses="LabelKeyText" />
            <LineEdit Name="PasswordEdit" Access="Public" HorizontalExpand="True" />
        </BoxContainer>
        <BoxContainer Orientation="Vertical" SeparationOverride="2">
            <Label Text="{Loc 'recovery-password-confirm-label'}" StyleClasses="LabelKeyText" />
            <LineEdit Name="ConfirmEdit" Access="Public" HorizontalExpand="True" />
        </BoxContainer>
        <Label Name="StatusLabel" Access="Public" />
        <Button Name="SaveButton" Access="Public"
                Text="{Loc 'recovery-password-save-button'}" HorizontalExpand="True" />
    </BoxContainer>
</recoveryPassword:RecoveryPasswordWindow>
