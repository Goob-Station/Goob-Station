# Feed

bloodsucker-feed-start-neck-user = You sink your fangs into {$target}'s neck.
bloodsucker-feed-start-neck-others = {$user} closes {$user_their} mouth around {$target}'s neck!
bloodsucker-feed-start-wrist-user = You slip your fangs into {$target}'s wrist.
bloodsucker-feed-start-wrist-others = {$user} puts {$target}'s wrist up to {$user_their} mouth.
bloodsucker-feed-dazed = {$target} looks dazed, and will not remember this.
bloodsucker-feed-interrupt-user = Your teeth are ripped from {$target}'s throat. {$target_their} blood sprays everywhere!
bloodsucker-feed-interrupt-others = {$user} is ripped from {$target}'s throat. {$target_their} blood sprays everywhere!
bloodsucker-feed-stop = You slowly release {$target}.
bloodsucker-feed-mouse = You recoil at the taste of a lesser lifeform.
bloodsucker-feed-noticed = Feed noticed!
bloodsucker-feed-starting = Feeding off {$target}...
bloodsucker-feed-warning-safe = Your victim's blood is at an unsafe level.
bloodsucker-feed-warning-danger = Your victim's blood is dangerously low.
bloodsucker-feed-warning-fatal = Your victim's blood is fatally low!

