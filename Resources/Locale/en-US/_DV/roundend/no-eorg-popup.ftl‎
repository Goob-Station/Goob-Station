no-eorg-popup-title = Goobstation
no-eorg-popup-label = Welcome to the End of Round!
no-eorg-popup-message = [bold]End-of-round grief (EORG)[/bold] is not allowed at Goobstation (MRP Only). Please stay in character until the lobby screen appears to maintain an immersive environment for everyone. Thank you for respecting the community rules!
no-eorg-popup-rule = [bold][color=#a4885c]Rule 15: End of Round Griefing (MRP Only).[/color][/bold]
no-eorg-popup-rule-text =  Non-antagonists are not allowed to engage in End of Round Griefing both on the Evac Shuttle and when they arrive at Centcomm. Preparing items for End of Round Griefing such as gas canisters of flammable liquid or explosives as a non-antagonist is also against the rules.
no-eorg-popup-antag-text = [color=red]However, Antagonists are allowed to engage in EORG and they should strive to make it interesting.[/color]
no-eorg-popup-close-button = Sounds good!
no-eorg-popup-close-button-wait = The close button will be enabled after {$time} seconds.
no-eorg-popup-skip-checkbox = Don't show this again.
