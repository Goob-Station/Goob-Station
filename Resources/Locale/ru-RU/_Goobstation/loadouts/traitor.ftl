# PDA Uplink Option
loadout-traitor-uplink-pda-name = КПК Аплинк
loadout-traitor-uplink-pda-desc = Ваш Аплинк будет спрятан в КПК. Введите код в рингтоне для доступа к магазину.

# Pen Uplink Option
loadout-traitor-uplink-pen-name = Аплинк ручка
