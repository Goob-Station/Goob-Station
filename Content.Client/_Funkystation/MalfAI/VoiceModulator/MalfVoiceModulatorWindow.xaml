<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               Title="{Loc malfai-voice-modulator-title}"
               MinWidth="460">
    <BoxContainer Orientation="Vertical" Margin="8">
        <Label Text="{Loc malfai-voice-modulator-prompt}" Margin="0 0 0 4"/>
        <LineEdit Name="NameInput"
                  PlaceHolder="{Loc malfai-voice-modulator-placeholder}"
                  Margin="0 0 0 8"/>
        <BoxContainer Orientation="Horizontal" Margin="0 0 0 8">
            <Label Text="{Loc voice-mask-name-change-speech-style}" Margin="0 0 4 0"/>
            <OptionButton Name="SpeechVerbSelector" HorizontalExpand="True"/> <!-- Populated in LoadVerbs -->
        </BoxContainer>
        <Label Text="{Loc voice-mask-icon-label}"/>
        <GridContainer Name="IconGrid" Columns="10" Margin="0 0 0 8">
            <!-- Job icon buttons are generated in code -->
        </GridContainer>
        <Button Name="ConfirmButton"
                Text="{Loc malfai-voice-modulator-confirm}"/>
    </BoxContainer>
</DefaultWindow>
