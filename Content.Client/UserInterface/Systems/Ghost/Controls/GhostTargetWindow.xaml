<DefaultWindow xmlns="https://spacestation14.io"
               Title="{Loc 'ghost-target-window-title'}" MinSize="450 450" SetSize="450 450">
    <BoxContainer Orientation="Vertical" HorizontalExpand="True" SizeFlagsStretchRatio="0.4">
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" SeparationOverride="4" Margin="0 4">
            <Button Name="GhostnadoButton" Text="{Loc 'ghost-target-window-warp-to-most-followed'}" HorizontalExpand="True" />
            <!-- DOWNSTREAM-TPirates: ghost follow menu update -->
            <Button Name="RefreshButton" MinSize="14 14" />
        </BoxContainer>
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" SeparationOverride="4" Margin="0 2" VerticalAlignment="Center">
            <Label Name="ViewModeLabel" Text="{Loc 'ghost-target-window-color-mode-label'}" VerticalAlignment="Center" />
            <Button Name="ViewModeButton" MinSize="100 24" />
        </BoxContainer>
        <LineEdit Name="SearchBar" PlaceHolder="Search" HorizontalExpand="True" Margin="0 4" />
        <ScrollContainer Name="GhostScroll" VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="False">
            <BoxContainer Name="SectionsContainer" Orientation="Vertical" SeparationOverride="4" HorizontalExpand="True" />
        </ScrollContainer>
        <!-- DOWNSTREAM-TPirates: ghost follow menu update (end) -->
    </BoxContainer>
</DefaultWindow>
